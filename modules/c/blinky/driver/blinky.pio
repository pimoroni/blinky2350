.program blinky
.side_set 1 opt

; out pins:
;
; - 3: row select bit 0
; - 4: row select bit 1
; - 5: row select bit 2
; - 6: row select bit 3

; set pins:
;
; - 0: column data (base)
; - 1: column latch
; - 2: column blank
; - 3: row data
; - 4: row clock

; sideset pin:
;
; - 0: column clock

; for each row:
;   for each bcd frame:
;           0: 00011111                           // row pixel count (minus one)
;           1: xxxxrrrr                           // row select bits
;     2  - 65: xxxxxbgr, xxxxxbgr, xxxxxbgr, ...  // pixel data
;     66 - 67: xxxxxxxx, xxxxxxxx                 // dummy bytes to dword align
;     68 - 71: tttttttt, tttttttt, tttttttt       // bcd tick count (0-65536)
; 
; .. and back to the start


.wrap_target

    out pins, 2 [2]                 ; output column clock and row data phase A
    out pins, 2 [2]                 ; output column clock and row data phase B
    out null, 4                     ; discard four dummy bits

    out y, 8                        ; get row pixel count (minus 1 because test is pre decrement)
pixels:
    ; bit
    out x, 1            side 0  [1] ; pull in colour bit from OSR into register X, clear clock
    set pins, 0b100                 ; clear data bit, blank high
    jmp !x bit_end                  ; if bit was zero jump
    set pins, 0b101                 ; set data bit, blank high
  bit_end:
    out null, 7         side 1 [2]  ; clock in bit

  jmp y-- pixels

  out null, 24                      ; discard dummy bytes

  set pins, 0b110 [5]               ; latch high, blank high
  set pins, 0b000                   ; blank low (enable output)

; loop over bcd delay period
  out y, 32                         ; get bcd delay counter value
bcd_delay:
  jmp y-- bcd_delay

  set pins 0b100                    ; blank high (disable output)

.wrap